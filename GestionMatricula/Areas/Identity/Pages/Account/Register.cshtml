@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    :root {
        --institucional-teal: #176B7B;
        --institucional-brown: #782E16;
    }

    .register-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding-top: 20px;
    }

    .welcome-title {
        font-size: 1.8rem;
        font-weight: bold;
        color: #000000;
        margin-top: 20px;
        margin-bottom: 35px;
    }

    .register-card {
        background-color: var(--institucional-teal);
        border-radius: 12px;
        padding: 40px 50px;
        max-width: 900px;
        width: 100%;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }

    .register-card .form-label {
        color: #ffffff;
        font-weight: bold;
        font-size: 1.3rem;
        margin-bottom: 10px;
    }


    .register-card .form-control {
        border-radius: 10px;
        height: 48px;
        border: none;
        font-size: 1.1rem;
        padding-left: 15px;
    }


    .btn-registrar {
        background-color: var(--institucional-brown);
        color: #ffffff;
        border: none;
        padding: 12px 45px;
        border-radius: 8px;
        font-size: 1.2rem;
        font-weight: 500;
        transition: background-color 0.2s ease;
    }

    .btn-registrar:hover {
        background-color: #5c2210;
        color: #ffffff;
    }

    .login-text {
        color: #ffffff;
        font-size: 0.95rem;
        margin-bottom: 2px;
    }

    .login-link {
        color: #24b6d0;
        text-decoration: underline;
        font-size: 0.95rem;
    }

    .login-link:hover {
        color: #ffffff;
    }
</style>


<div class="register-container container">
    <div class="text-center">
        <h2 class="welcome-title">¡Regístrese aquí!</h2>
    </div>
    <div class="d-flex justify-content-center mb-5">
        <div class="register-card">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                
                <div class="row">

                
                    <div class="col-md-6 px-4">
                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label">Correo</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="" />
                            <span asp-validation-for="Input.Email" class="text-warning small"></span>
                        </div>

           
                    </div>

             
                    <div class="col-md-6 px-4">
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label">Contraseña</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                            <span asp-validation-for="Input.Password" class="text-warning small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar Contraseña</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-warning small"></span>
                        </div>
                    </div>

                </div>

         
                <div class="text-center mt-4 mb-3">
                    <button id="registerSubmit" type="submit" class="btn-registrar">Registrarse</button>
                </div>

                <div class="text-center mt-4">
                    <p class="login-text">Ya tiene una cuenta?</p>
                    <a asp-page="./Login" class="login-link">Iniciar Sesión</a>
                </div>
            </form>

        </div>
        
    </div>
    
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
