@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<style>
    :root {
        --institucional-teal: #176B7B;
        --institucional-brown: #782E16;
    }

    .login-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding-top: 20px;
    }

    /* Título de bienvenida */
    .welcome-title {
        font-size: 1.8rem;
        font-weight: bold;
        color: #000000;
        margin-top: 20px;
        margin-bottom: 35px;
    }

    /* Tarjeta azul de Login */
    .login-card {
        background-color: var(--institucional-teal);
        border-radius: 12px;
        padding: 40px 50px;
        max-width: 500px;
        width: 100%;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    }

    /* Etiquetas de texto (Correo y Contraseña) */
    .login-card .form-label {
        color: #ffffff;
        font-weight: bold;
        font-size: 1rem;
        margin-bottom: 10px;
    }

    /* Inputs blancos redondeados */
    .login-card .form-control {
        border-radius: 10px;
        height: 48px;
        border: none;
        font-size: 1rem;
        padding-left: 15px;
    }

    /* Botón Iniciar Sesión */
    .btn-iniciar-sesion {
        background-color: var(--institucional-brown);
        color: #ffffff;
        border: none;
        padding: 12px 45px;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 500;
        transition: background-color 0.2s ease;
    }

    .btn-iniciar-sesion:hover {
        background-color: #5c2210;
        color: #ffffff;
    }

   

    .link {
        color: #782E16;
        text-decoration: underline;
        font-size: 0.95rem;
    }

    .link:hover {
        color: #ffffff;
    }
</style>
<div class="login-container container">
    <div class="text-center">
        <h2 class="welcome-title">Bienvenido al sistema de matricula</h2>
    </div>
    <div class ="d-flex justify-content-center mb-5">
        <div class="login-card">
            <form id="account" method="post">
     
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label">Correo</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="" />
                    <span asp-validation-for="Input.Email" class="text-warning small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="" />
                    <span asp-validation-for="Input.Password" class="text-warning small"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div class="text-center mt-5 mb-4">
                    <button id="login-submit" type="submit" class="btn-iniciar-sesion">Iniciar Sesión</button>
                </div>
                <div class="mt-4">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="link">Olvido su contraseña?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link">Registrarse como nuevo usuario</a>
                    </p>
                
                </div>
            </form>
        </div>
    </div>
    
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
